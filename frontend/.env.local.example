# URL da API Laravel — usada pelas API routes do Next.js (server-side)
API_URL=http://nginx:80/api
# Quando rodando fora do Docker (localhost):
# API_URL=http://localhost:8000/api

# Exposto ao client (uso restrito — preferimos passar pelas API routes do Next)
NEXT_PUBLIC_APP_NAME=Framily
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SOCIAL_LOGIN_ENABLED=false

# Cookie de sessão (proxy para Sanctum) — não comitar segredos reais
SESSION_COOKIE_NAME=framily_session
SESSION_COOKIE_SECURE=false
