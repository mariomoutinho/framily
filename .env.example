# ============================================
# Framily — variáveis compartilhadas (Docker)
# ============================================
# Copie este arquivo para .env na raiz e ajuste valores.
# Cada serviço (frontend/backend) também tem seu .env.example próprio.

# ---- App ----
APP_NAME=Framily
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# URLs locais
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_URL=http://localhost:8000/api

# ---- MySQL ----
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=framily
DB_USERNAME=framily
DB_PASSWORD=framily
DB_ROOT_PASSWORD=root

# ---- Sanctum / Auth ----
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# ---- Login social (futuro) ----
SOCIAL_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${BACKEND_URL}/api/auth/social/google/callback

# ---- Frontend (expostas com prefixo NEXT_PUBLIC_) ----
NEXT_PUBLIC_APP_NAME=Framily
NEXT_PUBLIC_API_URL=${API_URL}
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SOCIAL_LOGIN_ENABLED=false
